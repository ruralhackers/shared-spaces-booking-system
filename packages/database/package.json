{
  "name": "@dfs/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "db:sql": "bun --env-file=../../.env.local prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script -o prisma/schema.sql",
    "db:push:dev": "bun --env-file=../../.env.dev prisma db push",
    "db:push:prd": "bun --env-file=../../.env prisma db push",
    "db:push": "bun --env-file=../../.env.local prisma db push",
    "db:seed": "bun --env-file=../../.env.local run src/seed.ts",
    "db:fresh": "bun migrate:reset && bun db:push && bun db:seed",
    "db:sync": "bun generate && bun db:sql && bun db:push",
    "db:studio": "bun --env-file=../../.env.local prisma studio",
    "migrate:dev": "bun --env-file=../../.env.local prisma migrate dev",
    "migrate:deploy": "bun --env-file=../../.env.local prisma migrate deploy",
    "migrate:reset": "bun --env-file=../../.env.local prisma migrate reset",
    "db:reset": "bun -e \"import {rmSync} from 'fs'; rmSync('../../data/pglite', {recursive:true,force:true})\" && bun --env-file=../../.env.local run src/init-schema.ts"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "@electric-sql/pglite": "^0.4.5",
    "pglite-prisma-adapter": "^0.7.2"
  },
  "devDependencies": {
    "prisma": "7.8.0",
    "prisma-json-types-generator": "4.1.1",
    "typescript": "latest"
  }
}

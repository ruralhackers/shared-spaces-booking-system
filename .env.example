# Authentication
# Generate a random secret: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# Docker ports (used by docker-compose.yml - Redis only)
REDIS_PORT=6379

# Database (PGlite dataDir path — pglite: prefix, path relative to project root)
DATABASE_URL=pglite:./data/pglite
REDIS_URL="redis://localhost:6379"

# Email (optional - for notifications)
# sendgrid
EMAIL_SERVER=smtp://apikey:<apiKey>@smtp.sendgrid.net:587
# resend
# RESEND_API_KEY=re_xxxxx
EMAIL_FROM=hello@example.com

# Google OAuth (optional - https://console.cloud.google.com/apis/credentials)
# Redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Shared-spaces booking
# Required: secret key for admin access (use a long random string)
ADMIN_KEY="change-me-to-a-long-random-secret"
# Optional: Slack incoming webhook URL for booking notifications
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
# Timezone for the house (IANA tz name)
TZ="Europe/Madrid"
# Site branding (shown in the webapp nav and PWA manifest)
SITE_NAME="Shared Spaces"
# SITE_LOGO_URL="https://example.com/logo.png"
# SITE_SHORT_NAME is optional, defaults to first 12 chars of SITE_NAME
# SITE_SHORT_NAME="Shared"
# SITE_WEBAPP_URL must be the webapp origin (where icons are served from)
SITE_WEBAPP_URL="http://localhost:3000"
